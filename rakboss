	TweenService:Create(toast, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Position = UDim2.new(0.5, -110, 1, -80)
	}):Play()
	task.delay(1.8, function()
		TweenService:Create(toast, TweenInfo.new(0.25), {
			BackgroundTransparency = 1,
			TextTransparency = 1,
			Position = UDim2.new(0.5, -110, 1, -70)
		}):Play()
	end)
end

-- ══════════════════════════════════════
--  Convert
-- ══════════════════════════════════════
local function doConvert()
	local raw = idBox.Text:match("^%s*(.-)%s*$")
	if raw == "" or not tonumber(raw) then
		-- Shake effect
		local origPos = idBox.Position
		local shakeInfo = TweenInfo.new(0.05, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, 4, true)
		TweenService:Create(idBox, shakeInfo, {
			Position = UDim2.new(origPos.X.Scale, origPos.X.Offset + 6, origPos.Y.Scale, origPos.Y.Offset)
		}):Play()
		idBoxStroke.Color = Color3.fromRGB(255, 80, 80)
		task.delay(0.4, function()
			idBoxStroke.Color = Color3.fromRGB(255, 182, 213)
		end)
		return
	end
	local hex = toHex(raw)
	if hex then
		hexValue = hex
		resultText.Text = hex
		resultText.TextColor3 = Color3.fromRGB(194, 24, 91)
		resultText.TextSize = 18
	end
end

